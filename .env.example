# Example environment configuration
# Copy this file to .env and fill in your values
# NEVER commit .env with real values!

# GitHub Authentication
# Get token from: gh auth login OR https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Authentication
# Option 1 (recommended local): run `npm run auth:ga4` to create .ga4-token.json
# Option 2 (CI): provide OAuth client credentials + refresh token
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
# Optional direct access token
# GOOGLE_OAUTH_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GA4 property ID
GA4_PROPERTY_ID=525629873

# Cloudflare Authentication
# Get token from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Account ID (found in Worker dashboard)
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Repository cache directory
REPO_CACHE_DIR=./.repo-cache

# Optional: Custom config file path
BRAND_CONFIG=./config/brand.config.json

# Optional: Debug logging
DEBUG=brand-analytics:*
